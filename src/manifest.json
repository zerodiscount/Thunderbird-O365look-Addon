{
  "manifest_version": 2,
  "name": "O365-Addon",
  "version": "1.2.2",
  "description": "Outlook style theming and a quick delete button.",
  "author": "zerodiscount & Open Source Community",
  "homepage_url": "https://github.com/zerodiscount/Thunderbird-O365look-Addon",
  "applications": {
    "gecko": {
      "id": "o365-addon-v2@zerodiscount.github.io",
      "strict_min_version": "115.0"
    }
  },
  "experiment_apis": {
    "cardsDelete": {
      "schema": "api/schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "script": "api/parent.js",
        "paths": [
          [
            "cardsDelete"
          ]
        ]
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  }
}